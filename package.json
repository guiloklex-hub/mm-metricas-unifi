{
  "name": "metricas-unifi",
  "version": "1.0.4",
  "private": false,
  "description": "Coleta, armazenamento e BI de métricas UniFi (multi-controller, multi-site) — open-source, self-hosted.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/guiloklex-hub/metricas-unifi"
  },
  "keywords": [
    "unifi",
    "ubiquiti",
    "metrics",
    "monitoring",
    "self-hosted",
    "open-source"
  ],
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "start": "tsx src/server/index.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc -p tsconfig.server.json && tsc -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/static": "^9.1.3",
    "@types/pdfkit": "^0.17.6",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.0.0",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.2",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.0",
    "ulid": "^3.0.2",
    "undici": "^7.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-router": "^1.85.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "drizzle-kit": "^0.31.10",
    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.2",
    "msw": "^2.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.6"
  }
}
