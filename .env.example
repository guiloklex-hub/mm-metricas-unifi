# metricas-unifi — exemplo de configuração
# Copie para .env e ajuste antes de subir o serviço.

# Onde a Web UI/API escuta
HOST=0.0.0.0
PORT=3002

# Connection string do PostgreSQL+TimescaleDB.
# Formato: postgresql://<user>:<pass>@<host>:<port>/<database>?sslmode=<mode>
#
# Cenário Docker (compose default):
#   DATABASE_URL=postgresql://metricas_app:${POSTGRES_PASSWORD}@timescaledb:5432/metricas_unifi
#
# Cenário Debian dedicado (veja docs/timescaledb-debian.md):
#   DATABASE_URL=postgresql://metricas_app:senha@db.exemplo.com:5432/metricas_unifi?sslmode=verify-full
DATABASE_URL=postgresql://metricas_app:CHANGE_ME@timescaledb:5432/metricas_unifi

# Senha do role `metricas_app` no Postgres — usada pelo docker-compose para
# subir o serviço `timescaledb` e referenciada na DATABASE_URL acima.
# Gere com `openssl rand -base64 32` e mantenha em sincronia com DATABASE_URL.
POSTGRES_PASSWORD=

# Chave de 32 bytes (gerar com `openssl rand -base64 32`).
# Usada para AES-GCM ao cifrar senhas dos controllers UniFi no banco.
# ATENÇÃO: trocar essa chave invalida todas as senhas guardadas.
MASTER_KEY=

# Segredo para assinar o JWT da sessão (gerar com `openssl rand -base64 64`).
JWT_SECRET=

# Ambiente (development | production | test)
NODE_ENV=development

# Nível de log do Pino (trace | debug | info | warn | error | fatal)
LOG_LEVEL=info

# Intervalo padrão de polling (segundos) para controllers sem override por controller.
DEFAULT_POLL_SECONDS=300

# Retenção (em dias). O TimescaleDB aplica a política automaticamente via
# `add_retention_policy`. As linhas mais antigas que essa janela são removidas
# dos chunks pelo background worker do Timescale.
RETENTION_5M_DAYS=30
RETENTION_1H_DAYS=365
